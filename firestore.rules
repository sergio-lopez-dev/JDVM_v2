rules_version = '2';

// ⚠️ BASE DE DATOS COMPARTIDA con la app legacy v1 (proyecto jdvm-d82b6).
// La app v2 vive AISLADA en colecciones con prefijo v2_*. Estas reglas:
//   1) PRESERVAN el comportamiento de la v1 (catch-all: cualquier usuario
//      autenticado puede leer/escribir cualquier documento) — NO tocar, rompería
//      la app en producción.
//   2) AÑADEN solo lectura pública a las colecciones v2_* que la web pública
//      (anónima: landing, estudio, carta, ficha de barbero) necesita leer.
//
// Nota de seguridad: al compartir la base con la v1 (que es permisiva), la v2
// hereda ese modelo (un usuario autenticado puede leer/escribir docs v2_*). No se
// puede endurecer sin enumerar y migrar las reglas de la v1. Las reglas estrictas
// originales de la v2 quedan en el historial de git por si se separa la base.
service cloud.firestore {
  match /databases/{database}/documents {
    // --- v2: lectura pública (la web pública es anónima) ---
    match /services_v2/{id} { allow read: if true; }
    match /barbers_v2/{id} { allow read: if true; }
    match /reviews_v2/{id} { allow read: if true; }
    match /images_v2/{id} { allow read: if true; }
    match /alerts_v2/{id} { allow read: if true; }
    match /rewards_v2/{id} { allow read: if true; }
    match /settings_v2/{id} { allow read: if true; }

    // --- v1 legacy (sin cambios) + escrituras/lecturas autenticadas de la v2 ---
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
