# ─────────────────────────────────────────────────────────────────────────────
# Firebase — configuración web del cliente.
# Estos valores son PÚBLICOS por diseño (van embebidos en el bundle del navegador);
# no son secretos. Proyecto v2 dedicado: jdvm-v2.
# Copia este archivo a .env (git-ignorado) y ajusta si hace falta.
# ─────────────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAl7pFF3il_cxGLNztRu5Sq5RbDX5SEcUI
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jdvm-v2.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=jdvm-v2
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=jdvm-v2.firebasestorage.app
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=135452502895
NUXT_PUBLIC_FIREBASE_APP_ID=1:135452502895:web:62d716839fc02fbd84569a
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-7NMEQRYMQC

# Emuladores de Firebase en desarrollo.
# 'true' = dev contra emuladores locales (projectId demo-jdvm).
# 'false' = la app se conecta al proyecto REAL jdvm-v2.
NUXT_PUBLIC_USE_EMULATORS=false

# Credenciales del Admin SDK (SSR de nuxt-vuefire + scripts). Pon aquí la ruta a
# tu service account JSON (git-ignorado, en secrets/). NO es público.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/<tu-service-account>.json
