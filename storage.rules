rules_version = '2';

// Storage de JDVM (galería del estudio, fotos de barberos, avatares).
// Lectura pública; escritura solo autenticada (se afina por carpeta más adelante).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
